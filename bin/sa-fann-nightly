#!/bin/bash
# sa-fann-nightly - Nightly FANN retraining with collapse detection
#
# Trains a fresh model on the full corpus, runs a sanity check against the
# holdout to detect model collapse (everything classified as one class, or
# all outputs stuck in one bucket), and rolls back only if collapse is
# detected. Intended to run from cron.
#
# The gate is intentionally lenient: anything better than "clearly broken"
# is allowed through. Accuracy tracking is the operator's responsibility.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

CORPUS_SPAM=/var/lib/mxguardian/corpus/spam
CORPUS_HAM=/var/lib/mxguardian/corpus/ham
TEST_SPAM=/var/lib/mxguardian/corpus/split/test/spam
TEST_HAM=/var/lib/mxguardian/corpus/split/test/ham
FANN_DIR=/var/lib/mxguardian/fann_data
LOG_DIR="$FANN_DIR/logs"
HISTORY_DIR="$FANN_DIR/history"
LOCK_FILE="$FANN_DIR/.nightly.lock"

# Collapse threshold: each class must get at least this % correct. A healthy
# model clears this easily; a collapsed one (all-spam, all-ham, all-unknown,
# or bimodal-but-wrong) will fail at least one side.
MIN_CLASS_RECALL=30
HISTORY_KEEP=7

export PATH=/usr/local/bin:/usr/bin:/bin

mkdir -p "$LOG_DIR" "$HISTORY_DIR"

TS=$(date +%Y%m%d_%H%M%S)
LOG="$LOG_DIR/nightly_$TS.log"

log()  { echo "[$(date '+%F %T')] $*" | tee -a "$LOG"; }
fail() { log "FAIL: $*"; exit 1; }

restore_backup() {
  local backup_dir="$1"
  if [[ -f "$backup_dir/fann.model" ]]; then
    cp "$backup_dir/fann.model"      "$FANN_DIR/fann.model"
    cp "$backup_dir/vocabulary.data" "$FANN_DIR/vocabulary.data"
    log "Restored previous model from $backup_dir"
  else
    log "No backup available to restore"
  fi
}

exec 9>"$LOCK_FILE"
flock -n 9 || fail "Another nightly run is in progress (lock held)"

cd "$REPO_DIR" || fail "Cannot cd to $REPO_DIR"

SPAM_COUNT=$(ls "$CORPUS_SPAM" | wc -l)
HAM_COUNT=$(ls "$CORPUS_HAM"  | wc -l)
log "Corpus: $SPAM_COUNT spam, $HAM_COUNT ham"

BACKUP="$HISTORY_DIR/model_$TS"
mkdir -p "$BACKUP"
cp "$FANN_DIR/fann.model"      "$BACKUP/" 2>/dev/null || log "No prior model to back up"
cp "$FANN_DIR/vocabulary.data" "$BACKUP/" 2>/dev/null || true
log "Backup dir: $BACKUP"

log "Starting training..."
START=$(date +%s)
perl -T -Ilib bin/sa-fann-train \
    --spam "$CORPUS_SPAM" \
    --ham  "$CORPUS_HAM" \
    --skip-rbl-checks --jobs 8 \
    --vocab-cap 10000 --epochs 1000 \
    --hidden2 50 \
    --prune-method df --min-df 0.001 --max-df 0.8 \
    --seed 42 \
    >> "$LOG" 2>&1
TRAIN_RC=$?
DURATION=$(( $(date +%s) - START ))
log "Training finished in ${DURATION}s (exit $TRAIN_RC)"

if [[ $TRAIN_RC -ne 0 ]]; then
  restore_backup "$BACKUP"
  fail "sa-fann-train exited $TRAIN_RC"
fi

log "Running accuracy test on holdout..."
REPORT=$(perl -T -Ilib bin/fann-test-accuracy \
    --skip-rbl-checks \
    "$TEST_SPAM" "$TEST_HAM" 2>&1)
TEST_RC=$?
echo "$REPORT" >> "$LOG"

if [[ $TEST_RC -ne 0 ]]; then
  restore_backup "$BACKUP"
  fail "fann-test-accuracy exited $TEST_RC"
fi

SPAM_RECALL=$(echo "$REPORT" | awk '
  /^SPAM test set/ { in_spam = 1 }
  in_spam && /FANN_SPAM.*correct/ { gsub(/[()%]/, ""); print $4; exit }')
HAM_RECALL=$(echo "$REPORT" | awk '
  /^HAM test set/ { in_ham = 1 }
  in_ham && /FANN_HAM.*correct/ { gsub(/[()%]/, ""); print $4; exit }')

log "Results: spam recall=${SPAM_RECALL}%, ham recall=${HAM_RECALL}%"

if [[ -z "$SPAM_RECALL" || -z "$HAM_RECALL" ]]; then
  restore_backup "$BACKUP"
  fail "Could not parse accuracy report"
fi

GATE_FAIL=0
awk -v r="$SPAM_RECALL" -v min="$MIN_CLASS_RECALL" 'BEGIN { exit !(r+0 < min+0) }' \
  && { log "Spam recall $SPAM_RECALL% below $MIN_CLASS_RECALL% — model appears collapsed"; GATE_FAIL=1; }
awk -v r="$HAM_RECALL" -v min="$MIN_CLASS_RECALL" 'BEGIN { exit !(r+0 < min+0) }' \
  && { log "Ham recall $HAM_RECALL% below $MIN_CLASS_RECALL% — model appears collapsed"; GATE_FAIL=1; }

if [[ $GATE_FAIL -eq 1 ]]; then
  restore_backup "$BACKUP"
  fail "Model collapse detected — previous model restored"
fi

log "Collapse check passed"

cd "$HISTORY_DIR"
ls -dt model_* 2>/dev/null | tail -n +$((HISTORY_KEEP + 1)) | xargs -r rm -rf
cd "$LOG_DIR"
ls -t nightly_*.log 2>/dev/null | tail -n +$((HISTORY_KEEP + 1)) | xargs -r rm -f

log "Done"
