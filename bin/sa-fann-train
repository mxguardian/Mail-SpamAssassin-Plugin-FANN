use strict;
use warnings;
use re 'taint';

use Errno qw(EBADF);
use File::Spec;
use Config;

use Getopt::Long;
use Pod::Usage;
use POSIX qw(locale_h setsid sigprocmask _exit);

POSIX::setlocale(LC_TIME,'C');

use AI::FANN qw(:all);
use Storable qw(store retrieve);
use File::Temp qw(tempdir);

use Mail::SpamAssassin;
use Mail::SpamAssassin::Util;

sub usage {
  pod2usage(
    -exitval => 64,
    -verbose => 0,
    -message => 'For more information, try sa-fann-train --help',
  );
}

my %opt = ();

GetOptions(
  'spam=s'             => \$opt{'spam'},
  'ham=s'              => \$opt{'ham'},
  'epochs=i'           => \$opt{'epochs'},
  'vocab-cap=i'        => \$opt{'vocab_cap'},
  'configpath|C=s'     => \$opt{'configpath'},
  'siteconfigpath=s'   => \$opt{'siteconfigpath'},
  'prefspath|p=s'      => \$opt{'prefspath'},
  'hidden=i'           => \$opt{'hidden'},
  'jobs|j=i'           => \$opt{'jobs'},
  'progress'           => \$opt{'progress'},
  'debug|D:s'          => \$opt{'debug'},
  'local|L'            => \$opt{'local'},
  'skip-rbl-checks'    => \$opt{'skip_rbl_checks'},
  'help|h'             => \$opt{'help'},
  'version|V'          => \$opt{'version'},
) or usage();

if ($opt{'help'}) {
  pod2usage(-exitval => 0, -verbose => 1);
}

if ($opt{'version'}) {
  require Mail::SpamAssassin::Plugin::FANN;
  print "sa-fann-train version $Mail::SpamAssassin::Plugin::FANN::VERSION (SpamAssassin " . Mail::SpamAssassin->Version() . ")\n";
  exit 0;
}

unless ($opt{'spam'} && $opt{'ham'}) {
  die "Both --spam <dir> and --ham <dir> are required.\n" .
      "Usage: sa-fann-train --spam <spam-dir> --ham <ham-dir> [options]\n";
}

# Untaint and validate directories
my $spam_dir = Mail::SpamAssassin::Util::untaint_file_path($opt{'spam'});
my $ham_dir  = Mail::SpamAssassin::Util::untaint_file_path($opt{'ham'});
die "Spam directory '$spam_dir' does not exist or is not a directory\n" unless -d $spam_dir;
die "Ham directory '$ham_dir' does not exist or is not a directory\n"   unless -d $ham_dir;

my $start_time = time();

# Create the SpamAssassin instance
my $spamtest = Mail::SpamAssassin->new(
  {
    rules_filename      => $opt{'configpath'},
    site_rules_filename => $opt{'siteconfigpath'},
    userprefs_filename  => $opt{'prefspath'},
    debug               => $opt{'debug'},
    local_tests_only    => $opt{'local'},
    dont_copy_prefs     => 1,
  }
);

$spamtest->init(1);

# Disable Bayes during training to avoid polluting the Bayes database
$spamtest->{conf}->{use_bayes} = 0;

# Optionally disable RBL checks while keeping other network tests enabled
if ($opt{'skip_rbl_checks'}) {
  $spamtest->{conf}->{skip_rbl_checks} = 1;
}

# Find the FANN plugin instance
my $nn_plugin;
foreach my $plugin (@{$spamtest->{plugins}->{plugins}}) {
  if ($plugin->isa('Mail::SpamAssassin::Plugin::FANN')) {
    $nn_plugin = $plugin;
    last;
  }
}
die "FANN plugin not loaded -- is it enabled in your configuration?\n"
  unless $nn_plugin;

# Set training mode to prevent check_cleanup from running inference
$nn_plugin->{training_mode} = 1;

# Read configuration, apply command-line overrides
my $conf = $spamtest->{conf};

my $nn_data_dir = $conf->{fann_data_dir};
unless (defined $nn_data_dir) {
  die "fann_data_dir not set in configuration\n";
}
$nn_data_dir = Mail::SpamAssassin::Util::untaint_file_path($nn_data_dir);
unless (-d $nn_data_dir) {
  die "fann_data_dir '$nn_data_dir' does not exist or is not a directory\n";
}

my $vocab_cap       = $opt{'vocab_cap'}  || $conf->{fann_vocab_cap};
my $train_epochs    = $opt{'epochs'}     || $conf->{fann_train_epochs};
my $learning_rate   = $conf->{fann_learning_rate};
my $momentum        = $conf->{fann_momentum};
my $train_algorithm = $conf->{fann_train_algorithm};
my $min_text_len    = $conf->{fann_min_text_len};

# Collect message files from spam and ham directories
my @spam_files = collect_files($spam_dir);
my @ham_files  = collect_files($ham_dir);

die "No spam files found in $spam_dir\n" unless @spam_files;
die "No ham files found in $ham_dir\n"   unless @ham_files;

print "Found " . scalar(@spam_files) . " spam files, " . scalar(@ham_files) . " ham files\n";

# Phase 1: Read all messages, build vocabulary, and collect rule hits
my $num_jobs = $opt{'jobs'} || 1;
print "Phase 1: Building vocabulary and collecting rule hits" .
      ($num_jobs > 1 ? " ($num_jobs workers)" : "") . "...\n";

my @all_entries = (
  (map { [$_, 1] } @spam_files),
  (map { [$_, 0] } @ham_files),
);

my %vocabulary_terms;
my $total_docs = 0;
my $spam_count = 0;
my $ham_count  = 0;
my @all_messages;

if ($num_jobs <= 1) {
  # Single-process mode
  my $results = process_batch($spamtest, $nn_plugin, \@all_entries, $min_text_len, $opt{'progress'});
  %vocabulary_terms = %{ $results->{vocabulary_terms} };
  $total_docs = $results->{total_docs};
  $spam_count = $results->{spam_count};
  $ham_count  = $results->{ham_count};
  @all_messages = @{ $results->{messages} };
} else {
  # Multi-process mode: split work across forked workers
  my $tmpdir = tempdir(CLEANUP => 1);
  $tmpdir = Mail::SpamAssassin::Util::untaint_file_path($tmpdir);

  # Split entries into chunks
  my @chunks;
  for my $i (0 .. $num_jobs - 1) {
    $chunks[$i] = [];
  }
  for my $i (0 .. $#all_entries) {
    push @{ $chunks[$i % $num_jobs] }, $all_entries[$i];
  }

  # Fork workers
  my @pids;
  for my $job_id (0 .. $num_jobs - 1) {
    next unless @{ $chunks[$job_id] };
    my $pid = fork();
    die "Failed to fork: $!\n" unless defined $pid;

    if ($pid == 0) {
      # Child process: create own SpamAssassin instance
      my $child_sa = Mail::SpamAssassin->new({
        rules_filename      => $opt{'configpath'},
        site_rules_filename => $opt{'siteconfigpath'},
        userprefs_filename  => $opt{'prefspath'},
        debug               => $opt{'debug'},
        local_tests_only    => $opt{'local'},
        dont_copy_prefs     => 1,
      });
      $child_sa->init(1);
      $child_sa->{conf}->{use_bayes} = 0;
      if ($opt{'skip_rbl_checks'}) {
        $child_sa->{conf}->{skip_rbl_checks} = 1;
      }

      my $child_plugin;
      foreach my $plugin (@{$child_sa->{plugins}->{plugins}}) {
        if ($plugin->isa('Mail::SpamAssassin::Plugin::FANN')) {
          $child_plugin = $plugin;
          last;
        }
      }
      die "FANN plugin not loaded in child\n" unless $child_plugin;
      $child_plugin->{training_mode} = 1;

      my $results = process_batch($child_sa, $child_plugin, $chunks[$job_id],
                                  $min_text_len, $opt{'progress'});

      my $out_path = File::Spec->catfile($tmpdir, "worker_$job_id.dat");
      $out_path = Mail::SpamAssassin::Util::untaint_file_path($out_path);
      store($results, $out_path) or die "Worker $job_id: failed to store results\n";
      $child_sa->finish();
      _exit(0);
    }
    push @pids, $pid;
  }

  # Wait for all workers
  for my $pid (@pids) {
    waitpid($pid, 0);
    if ($? != 0) {
      die "Worker process $pid exited with status $?\n";
    }
  }
  print STDERR "\r" . (" " x 40) . "\r" if $opt{'progress'} && -t STDERR;

  # Merge results from all workers
  for my $job_id (0 .. $num_jobs - 1) {
    my $out_path = File::Spec->catfile($tmpdir, "worker_$job_id.dat");
    $out_path = Mail::SpamAssassin::Util::untaint_file_path($out_path);
    next unless -f $out_path;
    my $results = retrieve($out_path) or die "Failed to load worker $job_id results\n";

    $total_docs += $results->{total_docs};
    $spam_count += $results->{spam_count};
    $ham_count  += $results->{ham_count};
    push @all_messages, @{ $results->{messages} };

    # Merge vocabulary counts
    my $worker_vocab = $results->{vocabulary_terms};
    for my $t (keys %$worker_vocab) {
      for my $k (qw(total docs spam ham)) {
        $vocabulary_terms{$t}{$k} = ($vocabulary_terms{$t}{$k} || 0) + ($worker_vocab->{$t}{$k} || 0);
      }
    }
  }
}

print "Processed $total_docs messages ($spam_count spam, $ham_count ham)\n";
print "Raw vocabulary: " . scalar(keys %vocabulary_terms) . " terms\n";
print "Rules seen: " . scalar(grep { /^rule:/ } keys %vocabulary_terms) . "\n";

# Phase 2: Prune vocabulary to vocab_cap terms by chi-squared score
# Chi-squared critical value at p=0.05 with 1 degree of freedom is 3.841
my $chi2_threshold = 3.841;
my %chi2;
foreach my $t (keys %vocabulary_terms) {
  my $a = $vocabulary_terms{$t}{spam} || 0;  # spam docs with term
  my $b = $vocabulary_terms{$t}{ham}  || 0;  # ham docs with term
  my $c = $spam_count - $a;                  # spam docs without term
  my $d = $ham_count  - $b;                  # ham docs without term
  my $denom = ($a + $b) * ($c + $d) * ($a + $c) * ($b + $d);
  if ($denom > 0) {
    $chi2{$t} = $total_docs * ($a * $d - $b * $c) ** 2 / $denom;
  } else {
    $chi2{$t} = 0;
  }
}

# Remove terms below chi-squared significance threshold
my $before_prune = scalar keys %vocabulary_terms;
delete $vocabulary_terms{$_} for grep { $chi2{$_} < $chi2_threshold } keys %vocabulary_terms;
my $after_sig = scalar keys %vocabulary_terms;
print "Pruned $before_prune -> $after_sig terms (chi-squared >= $chi2_threshold)\n";

# If still over vocab_cap, keep only the top terms
if ($after_sig > $vocab_cap) {
  my @top = sort { $chi2{$b} <=> $chi2{$a} } keys %vocabulary_terms;
  my %pruned;
  for my $i (0 .. $vocab_cap-1) {
    last unless defined $top[$i];
    $pruned{$top[$i]} = $vocabulary_terms{$top[$i]};
  }
  %vocabulary_terms = %pruned;
  print "Capped vocabulary to $vocab_cap terms\n";
}

# Split vocabulary into text terms (TF-IDF) and rule terms (binary)
my @vocab_keys = sort grep { !/^rule:/ } keys %vocabulary_terms;
my @rule_keys  = sort grep { /^rule:/ } keys %vocabulary_terms;
my $vocab_size = scalar @vocab_keys;
my $rule_vocab_size = scalar @rule_keys;
my $total_input_size = $vocab_size + $rule_vocab_size;
die "Empty vocabulary after processing -- check that messages have enough text\n" unless $vocab_size > 0;

my %vocab_index = map { $vocab_keys[$_] => $_ } 0..$#vocab_keys;
my %rule_index  = map { $rule_keys[$_] => $_ } 0..$#rule_keys;
my $N = $total_docs || 1;
my %idf;
foreach my $w (@vocab_keys) {
  my $df = $vocabulary_terms{$w}{docs} || 0;
  $idf{$w} = log( ($N + 1) / ($df + 1) ) + 1;
}

# Phase 3: Compute feature vectors (TF-IDF for text, binary for rules)
print "Phase 2: Computing feature vectors...\n";
my (@train_vectors, @train_labels);

foreach my $msg (@all_messages) {
  my $vec = $nn_plugin->compute_tfidf_vector($msg->{tokens}, \@vocab_keys, \%vocab_index, \%idf);

  # Append binary rule features
  if (@rule_keys) {
    my $hits = $msg->{rule_hits} || {};
    push @$vec, map { $hits->{ substr($_, 5) } ? 1 : 0 } @rule_keys;
  }

  push @train_vectors, $vec;
  push @train_labels, $msg->{label};
}

print "Computed " . scalar(@train_vectors) . " feature vectors (dimension: $total_input_size)\n";

# Phase 3: Create and train FANN network
print "Phase 3: Training neural network...\n";
my $num_hidden = $opt{'hidden'} || int(sqrt($total_input_size)) || 1;

my $network = AI::FANN->new_standard($total_input_size, $num_hidden, 1);
$network->hidden_activation_function(FANN_SIGMOID_STEPWISE);
$network->output_activation_function(FANN_SIGMOID_STEPWISE);
$network->learning_rate($learning_rate);
$network->learning_momentum($momentum);
$network->training_algorithm($train_algorithm);

# Build FANN TrainData
my @td_args;
for my $i (0 .. $#train_vectors) {
  push @td_args, $train_vectors[$i], [$train_labels[$i]];
}
my $train_data = AI::FANN::TrainData->new(@td_args);

print "Training: $total_input_size inputs ($vocab_size text + $rule_vocab_size rules), $num_hidden hidden, 1 output, $train_epochs epochs\n";
$network->train_on_data($train_data, $train_epochs, 0, 0);

# Save model
my $dataset_path = File::Spec->catfile($nn_data_dir, 'fann.model');
$dataset_path = Mail::SpamAssassin::Util::untaint_file_path($dataset_path);
eval {
  $network->save($dataset_path) or die "save failed";
  1;
} or do {
  die "Failed to save model to $dataset_path: " . ($@ || 'unknown') . "\n";
};

# Save vocabulary
my %vocabulary = (
  terms       => \%vocabulary_terms,
  _doc_count  => $total_docs,
  _spam_count => $spam_count,
  _ham_count  => $ham_count,
);

my $vocab_path = File::Spec->catfile($nn_data_dir, 'vocabulary.data');
$vocab_path = Mail::SpamAssassin::Util::untaint_file_path($vocab_path);
eval {
  store(\%vocabulary, $vocab_path) or die "store failed";
  1;
} or do {
  die "Failed to store vocabulary to $vocab_path: " . ($@ || 'unknown') . "\n";
};
print "Vocabulary saved to $vocab_path ($vocab_size text terms, $rule_vocab_size rule terms)\n";

my $elapsed = time() - $start_time;
print "\nTraining complete:\n";
print "  Messages:      $total_docs ($spam_count spam, $ham_count ham)\n";
print "  Text vocab:    $vocab_size terms\n";
print "  Rule features: $rule_vocab_size\n";
print "  Total inputs:  $total_input_size\n";
print "  Hidden units:  $num_hidden\n";
print "  Epochs:        $train_epochs\n";
print "  Model saved:   $dataset_path\n";
print "  Time:          ${elapsed}s\n";

$spamtest->finish();
exit 0;


# --- Helper functions ---

sub process_batch {
  my ($sa, $plugin, $entries, $min_text_len, $show_progress) = @_;

  my %vocab;
  my $total_docs = 0;
  my $spam_count = 0;
  my $ham_count  = 0;
  my @messages;

  my $total_files = scalar @$entries;
  my $files_done = 0;

  for my $entry (@$entries) {
    my ($file, $label) = @$entry;
    $files_done++;
    if ($show_progress && -t STDERR) {
      printf STDERR "\r  %d/%d", $files_done, $total_files;
    }

    my ($tokens, $rule_hits) = process_message($sa, $plugin, $file, $min_text_len);
    next unless $tokens && @$tokens;

    my @tokens = @$tokens;

    $total_docs++;
    if ($label) { $spam_count++; } else { $ham_count++; }

    # Accumulate vocabulary statistics
    my %seen;
    foreach my $t (@tokens) {
      $vocab{$t}{total} = ($vocab{$t}{total} || 0) + 1;
      $seen{$t} = 1;
    }
    foreach my $t (keys %seen) {
      $vocab{$t}{docs} = ($vocab{$t}{docs} || 0) + 1;
      if ($label) {
        $vocab{$t}{spam} = ($vocab{$t}{spam} || 0) + 1;
      } else {
        $vocab{$t}{ham} = ($vocab{$t}{ham} || 0) + 1;
      }
    }

    # Track rule hits as rule: prefixed terms
    if ($rule_hits) {
      for my $r (keys %$rule_hits) {
        my $rt = "rule:$r";
        $vocab{$rt}{total} = ($vocab{$rt}{total} || 0) + 1;
        $vocab{$rt}{docs} = ($vocab{$rt}{docs} || 0) + 1;
        if ($label) {
          $vocab{$rt}{spam} = ($vocab{$rt}{spam} || 0) + 1;
        } else {
          $vocab{$rt}{ham} = ($vocab{$rt}{ham} || 0) + 1;
        }
      }
    }

    push @messages, { tokens => \@tokens, label => $label, rule_hits => $rule_hits };
  }

  print STDERR "\r" . (" " x 40) . "\r" if $show_progress && -t STDERR;

  return {
    vocabulary_terms => \%vocab,
    total_docs       => $total_docs,
    spam_count       => $spam_count,
    ham_count        => $ham_count,
    messages         => \@messages,
  };
}

sub collect_files {
  my ($dir) = @_;
  opendir(my $dh, $dir) or die "Cannot open directory $dir: $!\n";
  my @files;
  while (my $entry = readdir($dh)) {
    next if $entry =~ /^\./;
    my $path = File::Spec->catfile($dir, $entry);
    next unless -f $path;
    $path = Mail::SpamAssassin::Util::untaint_file_path($path);
    push @files, $path;
  }
  closedir($dh);
  return sort @files;
}

sub process_message {
  my ($spamtest, $nn_plugin, $file, $min_text_len) = @_;

  my $raw;
  if (!open(my $fh, '<', $file)) {
    warn "Cannot open $file: $!\n";
    return (undef, undef);
  } else {
    local $/;
    $raw = <$fh>;
    close $fh;
  }
  return (undef, undef) unless defined $raw && length($raw) > 0;

  my $msg = $spamtest->parse(\$raw);
  return (undef, undef) unless $msg;

  # Check minimum text length before doing expensive work
  my $text_arr = $msg->get_visible_rendered_body_text_array();
  my $text = join("\n", @{$text_arr});
  if (!defined $text || length($text) < $min_text_len) {
    $msg->finish();
    return (undef, undef);
  }

  my $pms = $spamtest->check($msg);

  # Extract tokens using the same method as inference
  my $tokens = $nn_plugin->extract_tokens($msg, $pms);

  # Extract rule hits separately (binary features, not TF-IDF tokens)
  my %rule_hits;
  my $hit_str = $pms->get_names_of_tests_hit();
  if ($hit_str) {
    %rule_hits = map { $_ => 1 } split(/,/, $hit_str);
  }
  my $sub_str = $pms->get_names_of_subtests_hit();
  if ($sub_str) {
    $rule_hits{$_} = 1 for split(/,/, $sub_str);
  }

  $pms->finish();
  $msg->finish();
  return ($tokens, \%rule_hits);
}


=head1 NAME

sa-fann-train - train the SpamAssassin FANN model from message directories

=head1 SYNOPSIS

B<sa-fann-train> --spam <spam-dir> --ham <ham-dir> [options]

Options:

 --spam path                   Directory containing spam messages (required)
 --ham path                    Directory containing ham messages (required)
 --epochs N                    Override fann_train_epochs
 --vocab-cap N                 Override fann_vocab_cap
 --jobs N, -j N                Number of parallel workers (default: 1)
 --progress                    Show progress during message processing
 --configpath=path, -C path    Path to standard configuration directory
 --siteconfigpath=path         Path to site configuration directory
 --prefspath=file, -p file     Path to user preferences file
 --local, -L                   Use local tests only (no network tests)
 --skip-rbl-checks             Disable RBL checks (keep other network tests)
 --debug [area,...], -D        Print debugging messages
 --help, -h                    Print help message
 --version, -V                 Print version

=head1 DESCRIPTION

B<sa-fann-train> is a standalone training pipeline for the SpamAssassin
FANN plugin.  It reads spam and ham message directories directly,
builds a vocabulary in one pass, computes properly aligned TF-IDF feature
vectors, and trains a FANN neural network model.

The typical workflow is:

    sa-fann-train --spam /path/to/spam --ham /path/to/ham

The trained model and vocabulary are saved to the C<fann_data_dir>
directory and will be used automatically by the FANN plugin during
message scanning.

=head1 OPTIONS

=over 4

=item B<--spam> I<path>

Directory containing spam messages.  Required.

=item B<--ham> I<path>

Directory containing ham messages.  Required.

=item B<--epochs> I<N>

Override the C<fann_train_epochs> configuration setting.

=item B<--vocab-cap> I<N>

Override the C<fann_vocab_cap> configuration setting.

=item B<--jobs> I<N>, B<-j> I<N>

Number of parallel worker processes for Phase 1 (message processing and
vocabulary building).  Each worker creates its own SpamAssassin instance.
Useful when network tests are enabled, as workers spend most of their time
waiting on DNS lookups.  Default: 1.

=item B<--progress>

Show progress counter during message processing.

=item B<--configpath>=I<path>, B<-C> I<path>

Use the specified path for locating the configuration files, instead of the
default configuration file search path.

=item B<--siteconfigpath>=I<path>

Use the specified path for locating site-specific configuration files. The
default path is determined at build time.

=item B<--prefspath>=I<file>, B<-p> I<file>

Read user score preferences from I<file>.

=item B<--local>, B<-L>

Operate in local-tests-only mode.

=item B<--skip-rbl-checks>

Disable DNS blocklist (RBL) checks while keeping other network tests
enabled.  This is useful when you want network-based rules (e.g. SPF, DKIM)
but not the slower RBL lookups.

=item B<--debug> [I<area,...>], B<-D>

Produce debugging output. If no areas are listed, all debugging information
is printed. Diagnostic output can also be enabled for each area
individually; I<area> is the area of the code to instrument.

=item B<--help>, B<-h>

Print help message and exit.

=item B<--version>, B<-V>

Print version and exit.

=back

=head1 SEE ALSO

L<Mail::SpamAssassin::Plugin::FANN(3)>

=cut
