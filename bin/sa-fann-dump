#!/usr/bin/perl

use strict;
use warnings;
use Storable qw(retrieve);
use Getopt::Long;

my %opt;
GetOptions(
  'path=s'   => \$opt{path},
  'prefix=s' => \$opt{prefix},
  'rules'    => \$opt{rules},
  'chi2'     => \$opt{chi2},
  'top=i'    => \$opt{top},
  'help|h'   => \$opt{help},
) or die "Usage: sa-fann-dump [--path vocabulary.data] [--prefix body:] [--rules] [--chi2] [--top N]\n";

# --rules is shorthand for --prefix rule:
$opt{prefix} = 'rule:' if $opt{rules};

if ($opt{help}) {
  print <<'USAGE';
Usage: sa-fann-dump [options]

Options:
  --path file     Path to vocabulary.data (default: ~/.spamassassin/fann_data/vocabulary.data)
  --prefix str    Show only terms with this prefix (e.g. body:, subj:, from:, attach:)
  --rules         Shorthand for --prefix rule:
  --chi2          Sort by chi-squared score (most discriminative first)
  --top N         Show only the top N terms (use with --chi2)
  -h, --help      Show this help

USAGE
  exit 0;
}

my $vocab_path = $opt{path} || "$ENV{HOME}/.spamassassin/fann_data/vocabulary.data";
die "File not found: $vocab_path\n" unless -f $vocab_path;

my $vocab = retrieve($vocab_path) or die "Failed to load $vocab_path\n";

printf "Messages: %d (%d spam, %d ham)\n",
  $vocab->{_doc_count}, $vocab->{_spam_count}, $vocab->{_ham_count};

my %terms = %{ $vocab->{terms} || {} };
my @keys = sort keys %terms;

if (defined $opt{prefix}) {
  @keys = grep { index($_, $opt{prefix}) == 0 } @keys;
}

my $spam_count = $vocab->{_spam_count} || 0;
my $ham_count  = $vocab->{_ham_count}  || 0;
my $total_docs = $vocab->{_doc_count}  || 0;

# Compute chi-squared scores
my %chi2;
if ($opt{chi2}) {
  for my $t (@keys) {
    my $a = $terms{$t}{spam} || 0;
    my $b = $terms{$t}{ham}  || 0;
    my $c = $spam_count - $a;
    my $d = $ham_count  - $b;
    my $denom = ($a + $b) * ($c + $d) * ($a + $c) * ($b + $d);
    $chi2{$t} = $denom > 0 ? $total_docs * ($a * $d - $b * $c) ** 2 / $denom : 0;
  }
  @keys = sort { $chi2{$b} <=> $chi2{$a} } @keys;
  if ($opt{top}) {
    splice(@keys, $opt{top}) if @keys > $opt{top};
  }
}

printf "Terms: %d\n\n", scalar @keys;

if ($opt{chi2}) {
  printf "%-30s  %10s  %6s  %6s  %s\n", "Term", "Chi2", "Spam", "Ham", "Bias";
  printf "%-30s  %10s  %6s  %6s  %s\n", "-" x 30, "-" x 10, "-" x 6, "-" x 6, "-" x 4;
  for my $t (@keys) {
    my $spam = $terms{$t}{spam} || 0;
    my $ham  = $terms{$t}{ham}  || 0;
    my $spam_rate = $spam_count ? $spam / $spam_count : 0;
    my $ham_rate  = $ham_count  ? $ham  / $ham_count  : 0;
    my $bias = $spam_rate > $ham_rate ? 'SPAM' : $ham_rate > $spam_rate ? 'HAM' : '-';
    printf "%-30s  %10.2f  %6d  %6d  %s\n", $t, $chi2{$t}, $spam, $ham, $bias;
  }
} else {
  printf "%-30s  %6s  %6s  %6s\n", "Term", "Total", "Spam", "Ham";
  printf "%-30s  %6s  %6s  %6s\n", "-" x 30, "-" x 6, "-" x 6, "-" x 6;
  for my $t (@keys) {
    printf "%-30s  %6d  %6d  %6d\n",
      $t,
      $terms{$t}{total} || 0,
      $terms{$t}{spam}  || 0,
      $terms{$t}{ham}   || 0;
  }
}
